      "parameters": {
        "promptType": "define",
        "text": "=You are a job description analyzer.\n\nExtract information from the OCR text below.\n\nOCR Text:\n{{$json.ParsedResults[0].ParsedText}}\n\nReturn ONLY JSON:\n\n{\n  \"company\":\"\",\n  \"role\":\"\",\n  \"required_skills\":[],\n  \"job_description\":\"\"\n}",
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
