      "name": "JD Extraction",
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const raw = $node[\"JD Extraction\"].json.text;\n\nconst jd = JSON.parse(\n  raw.replace(/```json/g, \"\").replace(/```/g, \"\").trim()\n);\n\nconst requiredSkills = jd.required_skills || [];\n\nconst userSkills = [\"Python\", \"Excel\", \"Google Sheets\", \"n8n\", \"AI\", \"Automation\"];\n\nconst matched = requiredSkills.filter(skill =>\n  userSkills.some(userSkill =>\n    userSkill.toLowerCase() === skill.toLowerCase()\n  )\n);\n\nconst missing = requiredSkills.filter(skill => !matched.includes(skill));\n\nconst score = requiredSkills.length > 0\n  ? Math.round((matched.length / requiredSkills.length) * 100)\n  : 0;\n\nreturn [{\n  json: {\n    company: jd.company,\n    role: jd.role,\n    ATS_Score: score,\n    Matched_Skills: matched,\n    Missing_Skills: missing\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
