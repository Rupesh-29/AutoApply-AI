    {
      "parameters": {
        "promptType": "define",
        "text": "=You are an ATS Resume Optimization Expert.\n\nCompany:\n{{$json.company}}\n\nRole:\n{{$json.role}}\n\nCurrent ATS Score:\n{{$json[\"ATS Score\"]}}\n\nMatched Skills:\n{{$json[\"Matched Skills\"]}}\n\nMissing Skills:\n{{$json[\"Missing Skills\"]}}\n\nUser Profile:\n{{$json.user_profile}}\n\nAnalyze the user's profile against the job requirements.\n\nProvide:\n\n1. ATS Match Summary\n\n2. Skills that should be highlighted in the resume\n\n3. Missing skills that should be learned\n\n4. Resume bullet points that should be emphasized\n\n5. Projects that should be highlighted\n\n6. Certifications that should be highlighted\n\n7. Estimated ATS score after improvements\n\nKeep the response structured and professional.",
        "batching": {}
